-def calculate_sharpe_ratio(returns, risk_free_rate=0.0, periods=252):
-    if returns is None or returns.empty: return 0.0
-    clean = returns.dropna()
-    if clean.empty: return 0.0
-    std = clean.std()
-    if std == 0 or np.isnan(std): return 0.0
-    return float(((clean.mean() - risk_free_rate) / std) * np.sqrt(periods))
