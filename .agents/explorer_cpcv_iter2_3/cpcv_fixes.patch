-def calculate_sortino_ratio(returns, risk_free_rate=0.0, periods=252):
-    if returns is None or returns.empty: return 0.0
-    clean = returns.dropna()
-    if clean.empty: return 0.0
-    downside = clean[clean < risk_free_rate]
-    if downside.empty: return 0.0
-    downside_dev = np.sqrt(np.mean(downside ** 2))
-    if downside_dev == 0 or np.isnan(downside_dev): return 0.0
-    return float(((clean.mean() - risk_free_rate) / downside_dev) * np.sqrt(periods))
-
