-    m_e_term = max(0.0001, min(0.9999, 1 - 1.0 / (num_trials * np.e)))
-    e_max = (1 - euler_gamma) * stats.norm.ppf(m_term) + euler_gamma * stats.norm.ppf(m_e_term)
